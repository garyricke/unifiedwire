.DS_Store
.claude/
*.DS_Store
Thumbs.db

# Archived non-final banner background versions (kept locally, not in repo)
assets/banners-22apr2026/openai/*-v[0-9]*.png
assets/banners-22apr2026/openai/*-v[0-9]*.jpg
assets/banners-22apr2026/openai/bg-usa-diptych-serious.*

# Raw .jpeg outputs from openai-images (we rename to .jpg when promoting to live)
assets/banners-22apr2026/openai/*.jpeg

# 04C modern-worker iteration backups (only the live .jpg + user's
# top-add-a expansion reference are kept in the repo)
assets/banners-22apr2026/openai/bg-usa-c-modern-worker-pre-*.jpg
assets/banners-22apr2026/openai/bg-usa-c-modern-worker-*-padded*.jpg
assets/banners-22apr2026/openai/bg-usa-c-modern-worker-*-live.jpg
assets/banners-22apr2026/openai/bg-usa-c-modern-worker-symmetric-pad.jpg

# Nano-banana exploration superseded by openai/ versions
assets/banners-22apr2026/generated/

# Raw nano-banana / openai exploration outputs (kept locally only;
# final assets get copied into project image folders)
generated_imgs/

# Third-party reference materials used during spec-sheet planning
# (IEWC catalogs, internal source docs) — not for redistribution
0-spec-sheets-for-print/plan/

# Old WordPress site mirror — reference only, not deployed
unifiedwire.com-old-site/

# Pre-edit page snapshots
site/markets-backup-*/

# Media assets — served via Cloudinary, kept locally only.
# Code (HTML/CSS/JS), PDFs, XLSX, and Python scripts stay in git.
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
*.mp3
*.mp4
*.m4a
*.mov
*.webm
*.wav
*.svg
# Allowlist: cert/standards mark SVGs referenced inline by spec sheets
!site/assets/img/marks/*.svg

# Allowlist: print-suite landing imagery deployed alongside its HTML.
# (PDFs for this suite live on Cloudinary; only the .html/.css/imagery is here.)
!site/0-spec-sheets-for-print/**/*.png
!site/0-spec-sheets-for-print/**/*.svg
!site/assets/banners-22apr2026/unified-logo-redraw-with-*-text.png
